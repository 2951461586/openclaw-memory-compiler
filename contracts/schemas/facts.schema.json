{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/openclaw-memory-compiler/facts.schema.json",
  "title": "FactRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "scope",
    "text",
    "status",
    "sourceRefs",
    "firstSeenAt",
    "confidence"
  ],
  "properties": {
    "id": { "type": "string" },
    "scope": { "type": "string", "enum": ["user", "project", "system", "agent"] },
    "subject": { "type": ["string", "null"] },
    "attribute": { "type": ["string", "null"] },
    "value": { "type": ["string", "null"] },
    "text": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["confirmed", "inferred", "disputed", "stale"] },
    "tags": { "type": "array", "items": { "type": "string" }, "default": [] },
    "sourceRefs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "firstSeenAt": { "type": "string", "format": "date-time" },
    "lastConfirmedAt": { "type": ["string", "null"], "format": "date-time" },
    "expiresAt": { "type": ["string", "null"], "format": "date-time" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "supersedes": { "type": ["string", "null"] },
    "sourceDisciplineState": { "type": ["string", "null"] },
    "sourceDisciplineReason": { "type": ["string", "null"] },
    "sourceDisciplineGatedAt": { "type": ["string", "null"], "format": "date-time" },
    "sourceDisciplineBlockedAt": { "type": ["string", "null"], "format": "date-time" },
    "sourceDisciplineDowngradedAt": { "type": ["string", "null"], "format": "date-time" },
    "disputedAt": { "type": ["string", "null"], "format": "date-time" },
    "disputeReason": { "type": ["string", "null"] },
    "arbitratedAt": { "type": ["string", "null"], "format": "date-time" },
    "arbitrationReason": { "type": ["string", "null"] },
    "mergedFactIds": { "type": "array", "items": { "type": "string" }, "default": [] },
    "repairedFromId": { "type": ["string", "null"] },
    "supersededBy": { "type": ["string", "null"] },
    "reconciledAt": { "type": ["string", "null"], "format": "date-time" },
    "reconcileNote": { "type": ["string", "null"] },
    "rejectedAt": { "type": ["string", "null"], "format": "date-time" },
    "rejectionReason": { "type": ["string", "null"] }
  }
}
